{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geometry-gym/v1/xp_event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "schema_version", "created_at", "user_id", "topic_id", "workflow_run_id", "base", "correctness", "novelty", "spacing", "xp"
  ],
  "properties": {
    "id": {"type": "string"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "user_id": {"type": "string"},
    "topic_id": {"type": "string"},
    "edge_id": {"type": ["string", "null"]},
    "workflow_run_id": {"type": "string"},
    "base": {"type": "integer", "minimum": 0},
    "correctness": {"type": "number", "minimum": 0, "maximum": 1},
    "novelty": {"type": "number", "minimum": 0, "maximum": 1},
    "spacing": {"type": "number", "minimum": 0, "maximum": 1},
    "xp": {"type": "integer", "minimum": 0}
  }
}
