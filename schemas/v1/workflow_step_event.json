{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geometry-gym/v1/workflow_step_event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "schema_version", "created_at", "workflow_run_id", "step_name", "step_status", "input_json", "output_json", "bound_versions_json", "input_hash", "output_hash", "tool_schema_version"
  ],
  "properties": {
    "id": {"type": "string"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "workflow_run_id": {"type": "string"},
    "step_name": {"type": "string"},
    "step_status": {"type": "string", "enum": ["started", "delta", "completed", "failed", "waiting_for_input", "canceled"]},
    "tool_name": {"type": ["string", "null"]},
    "input_json": {"type": "object"},
    "output_json": {"type": "object"},
    "bound_versions_json": {"type": "object"},
    "input_hash": {"type": "string"},
    "output_hash": {"type": "string"},
    "tool_schema_version": {"type": "string"},
    "step_idempotency_key": {"type": ["string", "null"]},
    "started_at": {"type": ["string", "null"], "format": "date-time"},
    "finished_at": {"type": ["string", "null"], "format": "date-time"}
  }
}
