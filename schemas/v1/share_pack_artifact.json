{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geometry-gym/v1/share_pack_artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "created_at", "workflow_run_id", "user_id", "topic_id", "format", "payload_json"],
  "properties": {
    "id": {"type": "string"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "workflow_run_id": {"type": "string"},
    "user_id": {"type": "string"},
    "topic_id": {"type": "string"},
    "format": {"type": "string", "enum": ["image", "markdown", "bundle"]},
    "image_path": {"type": ["string", "null"]},
    "markdown_path": {"type": ["string", "null"]},
    "payload_json": {"type": "object"}
  }
}
