{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "geometry-gym/v1/node",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema_version", "created_at", "graph_version_id", "node_id", "label", "definition_1s"],
  "properties": {
    "id": {"type": "string"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "created_at": {"type": "string", "format": "date-time"},
    "graph_version_id": {"type": "string"},
    "node_id": {"type": "string"},
    "label": {"type": "string"},
    "definition_1s": {"type": "string"}
  }
}
